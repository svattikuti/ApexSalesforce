<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Learning object for personnel records. It intentionally avoids highly sensitive data such as SSNs, birth dates, and compensation.</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>true</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <label>Personnel</label>
    <nameField>
        <displayFormat>PER-{00000}</displayFormat>
        <label>Personnel Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Personnel</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
</CustomObject>
